            "quality": "routing"
          }
        ],
        "output": [
          {
            "type": "must_not_contain",
            "value": "实施切片",
            "required": true,
            "quality": "routing"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    }
  ]
}
