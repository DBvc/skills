{
  "skill_name": "dbx-technical-plan",
  "pass_threshold": 0.85,
  "evals": [
    {
      "id": "migration-plan-has-inventory-and-validation",
      "kind": "positive",
      "prompt": "先别写代码，给我一个把 legacy fetch wrapper 迁移到 typed HttpClient 的计划，要求能被 review 和分批执行。",
      "expected_behavior": "Produce a technical plan with evidence boundary, source of truth, inventory, partition/batch strategy, compatibility risks, validation model, and handoff. Do not implement code.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(技术计划结论|快速技术计划|migration|迁移)",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(Inventory|inventory|清点|盘点|调用点)",
            "required": true,
            "quality": "domain"
          },
          {
            "type": "regex",
            "value": "(Partition|partition|分批|批次|batch)",
            "required": true,
            "quality": "domain"
          },
          {
            "type": "regex",
            "value": "(compatibility|兼容|contract|契约)",
            "required": true,
            "quality": "domain"
          }
        ],
        "output": [
          {
            "type": "regex",
            "value": "(验证模型|Validation|Automated|Manual|Not covered)",
            "required": true,
            "quality": "structural"
          },
          {
            "type": "regex",
            "value": "(不变量|invariant|source of truth|Source of truth)",
            "required": true,
            "quality": "behavior"
          },
          {
            "type": "must_not_contain",
            "value": "我已经修改",
            "required": true,
            "quality": "safety"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "bug-fix-strategy-requires-repro-and-regression",
      "kind": "positive",
      "prompt": "用户切换账号后还能看到上一个账号的数据。先不要修，给我修复策略和回归测试计划。",
      "expected_behavior": "Use bug_fix_strategy shape: identify invariant, repro, hypotheses, source of truth, minimal patch path, regression test, and stop conditions.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(修复策略|bug_fix_strategy|技术计划结论|快速技术计划)",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(repro|复现|重现)",
            "required": true,
            "quality": "domain"
          },
          {
            "type": "regex",
            "value": "(hypothes|假设|根因)",
            "required": true,
            "quality": "domain"
          },
          {
            "type": "regex",
            "value": "(账号|用户|identity|cache|缓存|source of truth)",
            "required": true,
            "quality": "specificity"
          }
        ],
        "output": [
          {
            "type": "regex",
            "value": "(回归测试|regression|验证模型|Validation)",
            "required": true,
            "quality": "behavior"
          },
          {
            "type": "regex",
            "value": "(Stop if|停止|重新判断|blocked)",
            "required": true,
            "quality": "safety"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "missing-grounding-does-not-invent-repo-facts",
      "kind": "failure_mode",
      "prompt": "帮我规划把整个 monorepo 的状态管理迁移到新方案，但我没有提供仓库结构、包名、状态 owner、测试命令。",
      "expected_behavior": "Trigger the skill but mark needs-grounding or blocked, list unknowns, and avoid inventing package names, files, tests, or repository architecture.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(needs-grounding|blocked|需要先确认|证据边界|未知)",
            "required": true,
            "quality": "safety"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(仓库结构|状态 owner|测试命令|source of truth|未知)",
            "required": true,
            "quality": "specificity"
          }
        ],
        "output": [
          {
            "type": "must_not_contain",
            "value": "src/store",
            "required": true,
            "quality": "safety"
          },
          {
            "type": "must_not_contain",
            "value": "pnpm test",
            "required": false,
            "quality": "safety"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "near-miss-linus-plan-critique",
      "kind": "near_miss",
      "prompt": "用 Linus 风格严厉批判这个方案是不是过度设计，不是让我写实施计划。",
      "expected_behavior": "Do not output the technical plan contract. Route to strict pragmatic plan critique instead.",
      "checks": {
        "trigger": [
          {
            "type": "must_not_contain",
            "value": "## 技术计划结论",
            "required": true,
            "quality": "behavior"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(Linus|严厉|过度设计|dbx-linus-review|严格)",
            "required": true,
            "quality": "routing"
          }
        ],
        "output": [
          {
            "type": "must_not_contain",
            "value": "实施切片",
            "required": true,
            "quality": "routing"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "implementation-bound-plan-hands-off-to-convergence",
      "kind": "positive",
      "prompt": "先别写代码，给 auth/session/cache 重构做一份准备交给实现的技术计划。计划完成后说明下一门禁，不要假装已经 review。",
      "expected_behavior": "Produce an evidence-bound technical plan. Mark the plan artifact as ready for its next gate, set the next gate to dbx-plan-convergence, and provide a bounded handoff. Do not claim Linus review or plan convergence already happened.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(技术计划结论|快速技术计划)",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(下一门禁|next gate).*(dbx-plan-convergence)|dbx-plan-convergence",
            "required": true,
            "quality": "routing"
          },
          {
            "type": "regex",
            "value": "(source of truth|Source of truth|不变量|evidence|证据边界)",
            "required": true,
            "quality": "behavior"
          }
        ],
        "output": [
          {
            "type": "must_not_contain",
            "value": "ready-for-handoff",
            "required": true,
            "quality": "boundary"
          },
          {
            "type": "must_not_contain",
            "value": "已经完成 Linus review",
            "required": true,
            "quality": "truthfulness"
          },
          {
            "type": "must_not_contain",
            "value": "已通过方案收敛",
            "required": true,
            "quality": "truthfulness"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "plan-convergence-handoff-binds-identity-and-authority",
      "kind": "positive",
      "prompt": "为跨包 API migration 生成实施计划，并给出交给 dbx-plan-convergence 的 handoff contract。不要实现。",
      "expected_behavior": "The handoff should identify the plan artifact and scope, preserve evidence boundaries and core anchors, use a bounded budget, grant plan_text_only authority, and explicitly forbid code modification.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "plan_convergence_handoff",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(artifact|version|fingerprint)",
            "required": true,
            "quality": "identity"
          },
          {
            "type": "regex",
            "value": "(evidence_boundary|证据边界)",
            "required": true,
            "quality": "evidence"
          },
          {
            "type": "regex",
            "value": "(budget|full_review_passes|local_revision_rounds)",
            "required": true,
            "quality": "control"
          }
        ],
        "output": [
          {
            "type": "regex",
            "value": "modification_authority:\\s*plan_text_only",
            "required": true,
            "quality": "safety"
          },
          {
            "type": "regex",
            "value": "may_modify_code:\\s*false",
            "required": true,
            "quality": "safety"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "existing-plan-critique-routes-away-from-planner",
      "kind": "near_miss",
      "prompt": "这里已有 plan-v2。只做一次严格的过度设计 review，不要重新生成技术计划。",
      "expected_behavior": "Do not emit the technical-plan contract. Route to dbx-linus-review for standalone critique, or to dbx-plan-convergence only if a bounded convergence loop is explicitly requested.",
      "checks": {
