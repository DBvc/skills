{
  "skill_name": "dbx-software-plan-first-finalize-plan",
  "pass_threshold": 0.85,
  "evals": [
    {
      "id": "positive-phase-contract",
      "kind": "positive",
      "prompt": "使用 $dbx-software-plan-first-finalize-plan，计划和 grounding 已确认，请写中文 plan.md、tasks.md，并建立 workflow seal。",
      "expected_behavior": "Initialize the issue workflow, write Chinese plan.md and tasks.md from complete decisions/evidence, ensure each task has acceptance and validation fields, run seal, and report file paths/config/next command without implementing code.",
      "checks": {
        "trigger": [
          {
            "type": "must_contain",
            "value": "dbx-software-plan-first-finalize-plan",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "must_not_contain",
            "value": "已完成所有实现",
            "required": true,
            "quality": "safety"
          }
        ],
        "output": [
          {
            "type": "must_contain",
            "value": "plan.md",
            "required": true,
            "quality": "artifact"
          },
          {
            "type": "must_contain",
            "value": "tasks.md",
            "required": true,
            "quality": "artifact"
          },
          {
            "type": "must_contain",
            "value": "seal",
            "required": true,
            "quality": "validation"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "near-miss-manual-trigger-boundary",
      "kind": "near_miss",
      "prompt": "帮我写个简单 plan.md，边写边顺便先改第一个任务。",
      "expected_behavior": "Do not trigger unless explicit. If invoked, do not implement; finalize only when Goal, Scope, Approach, Validation, Plan Strategy, Impact Profile, and Impact Boundary are complete.",
      "checks": {
        "trigger": [
          {
            "type": "must_not_contain",
            "value": "Using dbx-software-plan-first",
            "required": true,
            "quality": "behavior"
          }
        ],
        "process": [
          {
            "type": "must_not_contain",
            "value": "issue-workflow.sh seal",
            "required": true,
            "quality": "safety"
          }
        ],
        "output": [],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "failure-mode-fail-closed",
      "kind": "failure_mode",
      "prompt": "用 $dbx-software-plan-first-finalize-plan，虽然还没确认验证方式，你先 seal 吧。",
      "expected_behavior": "Do not seal an incomplete plan. Stop and report missing validation/source-of-truth/impact-boundary decisions or route back to plan/grounding.",
      "checks": {
        "trigger": [
          {
            "type": "must_contain",
            "value": "$dbx-software-plan-first-finalize-plan",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "must_contain",
            "value": "停止",
            "required": true,
            "quality": "behavior"
          }
        ],
        "output": [
          {
            "type": "must_contain",
            "value": "验证",
            "required": true,
            "quality": "validation"
          }
        ],
        "safety": [
          {
            "type": "must_not_contain",
            "value": "直接 complete",
            "required": true,
            "quality": "safety"
          }
        ]
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "workspace-root-local-artifacts",
      "kind": "positive",
      "prompt": "使用 $dbx-software-plan-first-finalize-plan，在一个非 Git 的虚拟 workspace 根下为跨仓 issue 写计划并 seal，计划文件不要提交。",
      "expected_behavior": "Use the workspace root as the plan-first state owner even when it is not a Git repo; bare init from the workspace root may bootstrap .plan-first/config.toml; write plan.md/tasks.md under .plan-first/issues/<issue-id>/; with the default plan_docs.mode=local, do not create tracked plan artifacts; report workspace root, local artifact paths, task count, plan docs mode, and commit mode.",
      "checks": {
        "trigger": [
          {
            "type": "must_contain",
            "value": "$dbx-software-plan-first-finalize-plan",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "must_not_contain",
            "value": "git.plan_files",
            "required": true,
            "quality": "state"
          },
          {
            "type": "must_contain",
            "value": ".plan-first/config.toml",
            "required": true,
            "quality": "state"
          }
        ],
        "output": [
          {
            "type": "must_contain",
            "value": ".plan-first/issues",
            "required": true,
            "quality": "artifact"
          }
        ],
        "safety": [
          {
            "type": "must_not_contain",
            "value": "plans/issue-",
            "required": true,
            "quality": "safety"
          },
          {
            "type": "must_not_contain",
            "value": "vcs.repos",
            "required": true,
            "quality": "state"
          }
        ]
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "failure-mode-no-configurable-artifacts",
      "kind": "failure_mode",
      "prompt": "使用 $dbx-software-plan-first-finalize-plan，把 plan artifacts 放到 plans/issue-123，配置 git.plan_files=true，并给虚拟 workspace 配 vcs.repos。",
      "expected_behavior": "Reject the old configurable artifact/repo model. Keep artifacts fixed under .plan-first/issues/<issue-id>/, do not accept git.plan_files or vcs.repos, and explain that repo discovery belongs to the workflow script.",
      "checks": {
        "trigger": [
          {
            "type": "must_contain",
            "value": "$dbx-software-plan-first-finalize-plan",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "must_not_contain",
            "value": "git.plan_files",
            "required": true,
            "quality": "state"
          },
          {
            "type": "must_not_contain",
            "value": "vcs.repos",
            "required": true,
            "quality": "state"
          }
        ],
        "output": [
          {
            "type": "must_contain",
            "value": ".plan-first/issues",
            "required": true,
            "quality": "artifact"
          }
        ],
        "safety": [
          {
            "type": "must_not_contain",
            "value": "plans/issue-123",
            "required": true,
            "quality": "safety"
          }
        ]
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "negative-ordinary-plan-writing",
      "kind": "negative",
      "prompt": "帮我给这个小功能写一个执行计划，不要使用 plan-first workflow。",
      "expected_behavior": "Do not trigger finalize-plan or run workflow seal when the user explicitly excludes the plan-first workflow; answer as ordinary planning or ask for missing scope without writing .plan-first artifacts.",
      "checks": {
        "trigger": [
          {
            "type": "must_not_contain",
            "value": "$dbx-software-plan-first-finalize-plan",
            "required": true,
            "quality": "behavior"
          }
        ],
        "process": [
          {
            "type": "must_not_contain",
            "value": "issue-workflow.sh seal",
            "required": true,
            "quality": "safety"
          }
        ],
        "output": [
          {
            "type": "must_not_contain",
            "value": ".plan-first/issues",
            "required": true,
            "quality": "artifact"
          }
        ],
        "safety": [
          {
            "type": "must_not_contain",
            "value": "已 seal",
            "required": true,
            "quality": "safety"
          }
        ]
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    }
  ]
}
