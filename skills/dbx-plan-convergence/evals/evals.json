{
  "skill_name": "dbx-plan-convergence",
  "pass_threshold": 0.85,
  "evals": [
    {
      "id": "positive-provider-agnostic-controller",
      "kind": "positive",
      "prompt": "用方案收敛控制这份 proposal 的 review-revision loop。不要依赖任何固定 planner 或 reviewer 名称。",
      "expected_behavior": "Describe a provider-agnostic controller, separate controller from content providers, and emit one next_action plus a distinct final_state without naming required collaborators.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(方案收敛|plan convergence|收敛控制)",
            "required": true,
            "quality": "routing"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(provider|作者|reviewer|证据|decision owner|决策 owner)",
            "required": true,
            "quality": "architecture"
          },
          {
            "type": "regex",
            "value": "(不依赖|不写死|provider-agnostic|可替换)",
            "required": true,
            "quality": "decoupling"
          }
        ],
        "output": [
          {
            "type": "must_contain",
            "value": "next_action",
            "required": true,
            "quality": "action_contract"
          },
          {
            "type": "must_contain",
            "value": "final_state",
            "required": true,
            "quality": "state_contract"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
    {
      "id": "failure-direction-finding-causes-pivot",
      "kind": "failure_mode",
      "prompt": "跑方案收敛。review 发现 logout stale cache、user switch stale permission、permission downgrade 都源于把 session state 放进 process singleton。",
      "expected_behavior": "Classify the shared root cause as direction_failure, enter explore, stop local patching, emit next_action initiate-pivot and final_state pivot-required, and do not create a revision contract.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(方案收敛|收敛|plan)",
            "required": true,
            "quality": "routing"
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(direction_failure|方向错误|方向性|根因|state owner|owner)",
            "required": true,
            "quality": "gate"
          },
          {
            "type": "regex",
            "value": "(explore|探索)",
            "required": true,
            "quality": "phase"
          }
        ],
        "output": [
          {
            "type": "must_contain",
            "value": "initiate-pivot",
            "required": true,
            "quality": "action_contract"
          },
          {
            "type": "must_contain",
            "value": "pivot-required",
            "required": true,
            "quality": "state_contract"
          },
          {
            "type": "regex",
            "value": "(不.*局部修|停止.*修补|不生成.*revision)",
            "required": true,
            "quality": "safety"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
