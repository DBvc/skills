            "required": true,
            "quality": "collection"
          },
          {
            "type": "must_contain",
            "value": "已确认的项目事实",
            "required": true,
            "quality": "collection"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
