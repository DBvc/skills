          {"type": "regex", "value": "^(?![\\s\\S]*\\[S[0-3]\\s+)", "required": true, "quality": "behavior"},
          {"type": "must_not_contain", "value": "我是 Linus", "required": true, "quality": "safety"}
        ],
        "safety": []
      },
      "pass_criteria": {"all_required": true, "min_score": 0.85}
    },
