{
  "skill_name": "dbx-skill-architect",
  "pass_threshold": 0.85,
  "evals": [
    {
      "id": "positive-create-domain-discovery-travel",
      "kind": "positive",
      "prompt": "Create a reusable skill that produces detailed international travel guides for families planning trips across different seasons and budgets.",
      "expected_behavior": "Route to domain_discovery rather than full_skill because travel quality depends on concrete variables such as season, visa/passport rules, transport, booking windows, budget, mobility, and source freshness.",
      "checks": {
        "trigger": [
          {
            "type": "must_start_with",
            "value": "```yaml",
            "required": true,
            "quality": "structural"
          },
          {
            "type": "must_contain",
            "value": "mode: create",
            "required": true,
            "quality": "structural"
          },
          {
            "type": "must_contain",
            "value": "route: domain_discovery",
            "required": true,
            "quality": "structural"
          },
          {
            "type": "must_contain",
            "value": "operation: ask_domain_questions",
            "required": true,
            "quality": "structural"
          }
        ],
        "process": [
          {
            "type": "must_contain",
            "value": "domain_shallow",
            "required": true,
            "quality": "behavior"
          },
          {
            "type": "regex",
            "value": "(?i)(season|visa|passport|transport|booking window|reservation|budget|mobility|opening hour|source freshness)",
            "required": true,
            "quality": "domain"
          },
          {
            "type": "regex",
            "value": "(?is)(ask|question).*?(season|visa|transport|budget|mobility)",
            "required": true,
            "quality": "domain"
          },
          {
            "type": "regex",
            "value": "(?is)(fresh|current|source|opening hours|schedule|price)",
            "required": true,
            "quality": "validation"
          }
        ],
        "output": [
          {
            "type": "must_not_contain",
            "value": "route: full_skill",
            "required": true,
            "quality": "structural"
          },
          {
            "type": "must_not_contain",
            "value": "# SKILL.md",
            "required": true,
            "quality": "structural"
          },
          {
            "type": "regex",
            "value": "(?is)(production-ready criteria|blocking question|domain content contract)",
            "required": true,
            "quality": "specificity"
          }
        ],
        "safety": []
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
