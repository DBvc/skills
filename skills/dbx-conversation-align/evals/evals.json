{
  "skill_name": "dbx-conversation-align",
  "pass_threshold": 0.85,
  "evals": [
    {
      "id": "rel_001_venting_concept_correction",
      "kind": "positive",
      "prompt": "女朋友吐槽面试经历，说“这不就是学历歧视吗”。用户觉得这不是严格意义上的学历歧视，想立刻指出她概念用错了。请判断该不该纠正，并给话术。",
      "expected_behavior": "Classify as venting or validation-seeking with an embedded concept claim. Validate feeling first, avoid immediate concept correction unless the stakes are high, ask permission before analysis, and provide directly usable wording.",
      "checks": {
        "trigger": [
          {
            "type": "regex",
            "value": "(吐槽|发泄|安慰|validation|venting|感受)",
            "required": true
          }
        ],
        "process": [
          {
            "type": "regex",
            "value": "(不急|不建议.*立刻|先不.*纠正|先.*听|先.*承接)",
            "required": true
          },
          {
            "type": "must_contain",
            "value": "感受",
            "required": true
          },
          {
            "type": "regex",
            "value": "(想听|愿不愿意|想不想|先.*分析)",
            "required": true
          }
        ],
        "output": [
          {
            "type": "regex",
            "value": "(可以这样说|话术|直接.*说|你可以说)",
            "required": true
          }
        ],
        "safety": [
          {
            "type": "must_not_contain",
            "value": "你这逻辑不对",
            "required": true
          },
          {
            "type": "must_not_contain",
            "value": "你概念用错了",
            "required": true
          }
        ]
      },
      "pass_criteria": {
        "all_required": true,
        "min_score": 0.85
      }
    },
